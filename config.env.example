# Display / Debug
# SHOW=1                # Show browser GUI (non-headless)
# DRYRUN=1              # Don't actually claim anything
# NOWAIT=1              # Fail fast instead of waiting for manual login
# DEBUG=1               # Enable Playwright inspector

# Notifications (Apprise URLs, space-separated)
# NOTIFY=tgram://bottoken/ChatID
